# Lore — Slack configuration. Copy to .env and fill in your values.

# Required for Socket Mode (no public URL needed)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret

# Local model for research (Ollama, OpenAI-compatible). Without this, Lore falls back to a
# deterministic offline stub (loud warning in live mode) — set it to research with a real model.
OLLAMA_API_BASE=http://localhost:11434/v1
LORE_MODEL=llama3.2

# Consult the org-glossary MCP server (servers/glossary_server.py) to resolve domain
# terms/acronyms during research. Set to 1 to enable the MCP round-trip in live use.
LORE_MCP_GLOSSARY=1

# Channels to index. Leave unset to auto-index every channel Lore is a member of
# (needs channels:read). Or pin them explicitly: "C0123:pricing,C0456:leadership".
# LORE_CHANNELS=

# Logging
# LORE_LOG_LEVEL=INFO
